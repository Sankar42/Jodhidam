  .contact .btns{margin-top:30px}
  .contact .hours{margin-top:26px;color:var(--mist);font-size:.92rem}
  .address{display:inline-flex;align-items:center;gap:12px;margin-top:30px;padding:16px 24px;border:1px solid var(--line);border-radius:14px;background:rgba(13,16,48,.4);text-decoration:none;transition:.25s;cursor:pointer}
  .address:hover{border-color:var(--gold);background:rgba(35,38,95,.5);transform:translateY(-2px)}
  .address svg{width:26px;height:26px;color:var(--gold);flex-shrink:0}
