  .hero .name{margin-top:18px;font-size:1.35rem;color:var(--gold-soft);letter-spacing:.04em;font-weight:600}
  .hero .cred{color:var(--mist);font-size:.95rem;margin-top:4px}
  .hero p.lead{max-width:580px;margin:22px auto 34px;color:var(--mist);font-size:1.06rem}
  .btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}
