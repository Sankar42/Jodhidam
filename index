  .pari-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;position:relative}
  .pari{background:rgba(13,16,48,.45);border:1px solid var(--line);border-radius:16px;padding:24px 22px;transition:.3s}
  .pari:hover{border-color:rgba(217,178,94,.6);transform:translateY(-4px)}
  .pari .pi{width:38px;height:38px;color:var(--gold);margin-bottom:12px}
  .pari h4{font-family:"Cormorant Garamond",serif;font-size:1.25rem;color:var(--gold-soft);margin-bottom:6px}
  .pari p{color:var(--mist);font-size:.92rem}
  .feature .cta-row{margin-top:34px;position:relative}

  /* inquiry form */
  .form-card{background:linear-gradient(160deg,rgba(35,38,95,.5),rgba(13,16,48,.6));border:1px solid var(--line);border-radius:24px;padding:48px 44px;max-width:720px;margin:0 auto}
  .form-card h2{font-family:"Cormorant Garamond",serif;font-size:2.2rem;text-align:center;margin-bottom:8px}
  .form-card .sub{text-align:center;color:var(--mist);margin-bottom:32px}
  .field{margin-bottom:20px}
  .field label{display:block;font-size:.9rem;color:var(--gold-soft);margin-bottom:8px}
  .field input,.field select,.field textarea{width:100%;padding:13px 16px;border-radius:12px;background:rgba(10,12,38,.6);border:1px solid var(--line);color:var(--star);font-family:inherit;font-size:.98rem}
  .field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--gold)}
  .field textarea{resize:vertical}
  .frow{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  .form-card .send{width:100%;margin-top:8px;padding:16px;border:0;border-radius:999px;cursor:pointer;background:#1faa59;color:#fff;font-weight:800;font-size:1rem;font-family:inherit;transition:.25s;display:flex;align-items:center;justify-content:center;gap:10px}
  .form-card .send:hover{transform:translateY(-2px);background:#23c267}
  .form-card .send svg{width:22px;height:22px;fill:#fff}
  .form-note{text-align:center;color:var(--mist);font-size:.85rem;margin-top:16px}
  @media(max-width:760px){.frow{grid-template-columns:1fr}.form-card{padding:34px 22px}}

  .fab{position:fixed;right:20px;bottom:20px;z-index:60;width:58px;height:58px;border-radius:50%;background:#1faa59;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(0,0,0,.4);transition:.25s}
  .fab:hover{transform:scale(1.08)}
  .fab svg{width:30px;height:30px;fill:#fff}

  @media(max-width:760px){
    .navlinks{display:none}.burger{display:block}
    .about{grid-template-columns:1fr}
    .contact{padding:36px 22px}
  }
</style>
</head>
