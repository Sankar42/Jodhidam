  .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px}
  .card{background:linear-gradient(180deg,rgba(35,38,95,.45),rgba(23,26,69,.35));border:1px solid var(--line);border-radius:18px;padding:34px 30px;transition:.3s}
