  .btn-wa{background:#1faa59;color:#fff}
  .btn-wa:hover{transform:translateY(-2px);background:#23c267}
  .btn-ghost{border:1px solid var(--line);color:var(--star)}
  .btn-ghost:hover{border-color:var(--gold);color:var(--gold-soft)}

  .ring{margin:60px auto 0;width:min(330px,70vw);aspect-ratio:1;position:relative}
