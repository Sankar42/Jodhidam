      radial-gradient(900px 500px at 10% 20%, rgba(120,130,220,.12), transparent 55%),
      linear-gradient(180deg,#0a0c26 0%, var(--ink) 40%, var(--ink-2) 100%);
    color:var(--star);font-family:"Noto Sans Tamil","Catamaran",sans-serif;line-height:1.7;overflow-x:hidden;
  }
  .wrap{max-width:1120px;margin:0 auto;padding:0 24px}
  .disp{font-family:"Cormorant Garamond","Noto Sans Tamil",serif}

  .sky{position:fixed;inset:0;z-index:-1;pointer-events:none}
  .sky span{position:absolute;background:#fff;border-radius:50%;opacity:.7;animation:tw 4s infinite ease-in-out}
