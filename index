  .map-cue{display:inline-block;margin-top:8px;color:var(--gold);font-size:.82rem;font-weight:600}

  footer{border-top:1px solid var(--line);padding:46px 0 36px;margin-top:40px}
  .foot{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px}
  .foot .brand{font-size:1.05rem}
  .foot p{color:var(--mist);font-size:.86rem}
  .foot a{color:var(--mist);text-decoration:none;margin-left:18px}
